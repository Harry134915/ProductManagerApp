<Window x:Class="ProductManagerApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ProductManagerApp.Views.Converters"
        xmlns:views="clr-namespace:ProductManagerApp.Views"
        Title="商品管理系统" Height="600" Width="900"
        MinHeight="560" MinWidth="840"
        Background="#F5F6FA"
        Icon="/Assets/Idol.jpg"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <local:StringNotEmptyToVisibilityConverter x:Key="StringNotEmptyToVisibilityConverter"/>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="商品管理" FontSize="22" FontWeight="SemiBold"
                           Foreground="#303133"/>
                <TextBlock Text="维护商品编码、名称、价格、库存和描述"
                           Foreground="#909399" FontSize="12" Margin="0,4,0,0"/>
            </StackPanel>
        </Grid>

        <views:ProductFormView    Grid.Row="1" DataContext="{Binding Form}" />
        <views:DeleteConfirmView  Grid.Row="2" DataContext="{Binding DeleteConfirm}" />

        <!-- 状态提示留在主窗口，因为是全局的 -->
        <StackPanel Grid.Row="3" Margin="0,0,0,4">
            <Border Background="#FEF0F0" BorderBrush="#FBC4C4" BorderThickness="1"
                    CornerRadius="4" Padding="12,8" Margin="0,0,0,6"
                    Visibility="{Binding ErrorMessage, Converter={StaticResource StringNotEmptyToVisibilityConverter}}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="错误：" Foreground="#F56C6C" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="#F56C6C" FontSize="13"/>
                </StackPanel>
            </Border>

            <Border Background="#F0F9EB" BorderBrush="#B3E19D" BorderThickness="1"
                    CornerRadius="4" Padding="12,8"
                    Visibility="{Binding StatusMessage, Converter={StaticResource StringNotEmptyToVisibilityConverter}}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="状态：" Foreground="#67C23A" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding StatusMessage}" Foreground="#67C23A" FontSize="13"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <views:ProductListView    Grid.Row="4" DataContext="{Binding List}" />
    </Grid>
</Window>
