<UserControl x:Class="ProductManagerApp.Views.ProductListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <Style x:Key="CenterCellText" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="RightCellText" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
        </Style>
    </UserControl.Resources>

    <Border Background="White" CornerRadius="6"
            BorderBrush="#EBEEF5" BorderThickness="1" Margin="0,6,0,0">
        <DockPanel>
            <Grid DockPanel.Dock="Top" Margin="14,10,14,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="商品列表" FontSize="14" FontWeight="SemiBold"
                           Foreground="#303133"/>
                <TextBlock Grid.Column="1" Text="单击一行可编辑商品信息"
                           Foreground="#B1B7C0" FontSize="11"
                           VerticalAlignment="Center"/>
            </Grid>

            <DataGrid ItemsSource="{Binding Products}"
                      SelectedItem="{Binding SelectedProduct}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#EBEEF5"
                      BorderThickness="0"
                      RowHeight="40"
                      ColumnHeaderHeight="38"
                      Background="White"
                      AlternatingRowBackground="#FAFAFA"
                      SelectionUnit="FullRow"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False">

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#F5F7FA"/>
                        <Setter Property="Foreground" Value="#606266"/>
                        <Setter Property="FontSize" Value="12"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Padding" Value="12,0"/>
                        <Setter Property="BorderBrush" Value="#EBEEF5"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="HorizontalContentAlignment" Value="Left"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Padding" Value="12,0"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Foreground" Value="#606266"/>
                        <Setter Property="FontSize" Value="13"/>

                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="DataGridCell">
                                    <Border Padding="{TemplateBinding Padding}"
                                            Background="{TemplateBinding Background}">
                                        <ContentPresenter VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>

                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#ECF5FF"/>
                                <Setter Property="Foreground" Value="#409EFF"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.CellStyle>

                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#ECF5FF"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F5F7FA"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="64"
                                        ElementStyle="{StaticResource CenterCellText}"/>
                    <DataGridTextColumn Header="商品编码" Binding="{Binding Code}" Width="130"/>
                    <DataGridTextColumn Header="商品名称" Binding="{Binding Name}" Width="160"/>
                    <DataGridTextColumn Header="价格" Binding="{Binding Price, StringFormat={}{0:F2}}" Width="100"
                                        ElementStyle="{StaticResource RightCellText}"/>
                    <DataGridTextColumn Header="库存" Binding="{Binding Stock}" Width="90"
                                        ElementStyle="{StaticResource CenterCellText}"/>
                    <DataGridTextColumn Header="描述" Binding="{Binding Description}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>
    </Border>
</UserControl>
