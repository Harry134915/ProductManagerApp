<UserControl x:Class="ProductManagerApp.Views.ProductListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:ProductManagerApp.Views.Converters"
             AutomationProperties.Name="商品列表区域"
             KeyboardNavigation.TabNavigation="Continue">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <local:TextEmptyToVisibilityConverter x:Key="TextEmptyToVisibilityConverter"/>

        <Style x:Key="CenterCellText" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Typography.NumeralAlignment" Value="Tabular"/>
        </Style>

        <Style x:Key="RightCellText" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="Typography.NumeralAlignment" Value="Tabular"/>
        </Style>

        <Style x:Key="DescriptionCellText" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextWrapping" Value="NoWrap"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
            <Setter Property="ToolTip" Value="{Binding Description}"/>
            <Setter Property="ToolTipService.InitialShowDelay" Value="400"/>
            <Setter Property="ToolTipService.ShowDuration" Value="30000"/>
        </Style>

        <Style x:Key="TableColumnHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F5F7FA"/>
            <Setter Property="Foreground" Value="#606266"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="BorderBrush" Value="#EBEEF5"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EBEEF5"/>
                    <Setter Property="Foreground" Value="#303133"/>
                </Trigger>
                <Trigger Property="SortDirection" Value="Ascending">
                    <Setter Property="Foreground" Value="#1F6FB2"/>
                    <Setter Property="Background" Value="#ECF5FF"/>
                </Trigger>
                <Trigger Property="SortDirection" Value="Descending">
                    <Setter Property="Foreground" Value="#1F6FB2"/>
                    <Setter Property="Background" Value="#ECF5FF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CenterColumnHeaderStyle"
               TargetType="DataGridColumnHeader"
               BasedOn="{StaticResource TableColumnHeaderStyle}">
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="RightColumnHeaderStyle"
               TargetType="DataGridColumnHeader"
               BasedOn="{StaticResource TableColumnHeaderStyle}">
            <Setter Property="HorizontalContentAlignment" Value="Right"/>
        </Style>
    </UserControl.Resources>

    <Border Background="White" CornerRadius="6"
            BorderBrush="#EBEEF5" BorderThickness="1" Margin="0,6,0,0">
        <DockPanel>
            <Grid DockPanel.Dock="Top" Margin="14,10,14,8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="商品列表" FontSize="14" FontWeight="SemiBold"
                           Foreground="#303133"/>
                <TextBlock Grid.Column="1" Text="单击一行可编辑商品信息"
                           Foreground="#B1B7C0" FontSize="11"
                           VerticalAlignment="Center"/>

                <Grid Grid.Row="1" Grid.ColumnSpan="2" Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="280"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="32"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="搜索商品" Foreground="#606266" FontSize="12"
                               VerticalAlignment="Center"/>

                    <Grid Grid.Column="2">
                        <TextBox x:Name="SearchBox"
                                 TabIndex="0"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 AutomationProperties.Name="搜索商品"
                                 AutomationProperties.HelpText="按商品编码或商品名称搜索"/>
                        <TextBlock Text="输入商品编码或名称"
                                   Foreground="#C0C4CC" FontSize="12"
                                   Margin="8,0,0,0" VerticalAlignment="Center"
                                   IsHitTestVisible="False">
                            <TextBlock.Visibility>
                                <MultiBinding Converter="{StaticResource TextEmptyToVisibilityConverter}">
                                    <Binding ElementName="SearchBox" Path="Text"/>
                                    <Binding ElementName="SearchBox" Path="IsKeyboardFocused"/>
                                </MultiBinding>
                            </TextBlock.Visibility>
                        </TextBlock>
                    </Grid>

                    <Button Grid.Column="4" Content="×" FontSize="17" Padding="0"
                            TabIndex="1"
                            ToolTip="清空搜索"
                            AutomationProperties.Name="清空搜索"
                            Style="{StaticResource DefaultButton}"
                            Command="{Binding ClearSearchCommand}"/>

                    <StackPanel Grid.Column="6" Orientation="Horizontal">
                        <Button Content="导入" Width="68" Margin="0,0,8,0"
                                TabIndex="2"
                                ToolTip="从 CSV 或 XLSX 文件批量导入商品"
                                Style="{StaticResource DefaultButton}"
                                Command="{Binding DataContext.ImportCommand,
                                    RelativeSource={RelativeSource AncestorType={x:Type Window}}}"/>
                        <Button Content="导出" Width="68" Margin="0,0,8,0"
                                TabIndex="3"
                                ToolTip="导出当前商品筛选结果"
                                Style="{StaticResource DefaultButton}"
                                Command="{Binding DataContext.ExportCommand,
                                    RelativeSource={RelativeSource AncestorType={x:Type Window}}}"/>
                        <Button Content="下载模板" Width="88"
                                TabIndex="4"
                                ToolTip="下载 CSV 或 XLSX 商品导入模板"
                                Style="{StaticResource DefaultButton}"
                                Command="{Binding DataContext.DownloadTemplateCommand,
                                    RelativeSource={RelativeSource AncestorType={x:Type Window}}}"/>
                    </StackPanel>

                    <TextBlock Grid.Column="8" Text="{Binding ResultCountText}"
                               AutomationProperties.LiveSetting="Polite"
                               Foreground="#909399" FontSize="12"
                               VerticalAlignment="Center"/>
                </Grid>
            </Grid>

            <Grid>
                <DataGrid x:Name="ProductDataGrid"
                          TabIndex="5"
                          ItemsSource="{Binding FilteredProducts}"
                          SelectedItem="{Binding SelectedProduct}"
                          PreviewKeyDown="OnProductDataGridPreviewKeyDown"
                          AutomationProperties.Name="商品列表"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#EBEEF5"
                          BorderThickness="0"
                          RowHeight="40"
                          ColumnHeaderHeight="38"
                          Background="White"
                          AlternatingRowBackground="#FAFAFA"
                          SelectionUnit="FullRow"
                          HeadersVisibility="Column"
                          CanUserSortColumns="True"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False">

                    <DataGrid.ColumnHeaderStyle>
                        <StaticResource ResourceKey="TableColumnHeaderStyle"/>
                    </DataGrid.ColumnHeaderStyle>

                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Padding" Value="12,0"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderBrush" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="Foreground" Value="#606266"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>

                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="DataGridCell">
                                        <Border Padding="{TemplateBinding Padding}"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}">
                                            <ContentPresenter VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>

                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#ECF5FF"/>
                                    <Setter Property="Foreground" Value="#1F6FB2"/>
                                </Trigger>
                                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                    <Setter Property="Background" Value="#F4F9FF"/>
                                    <Setter Property="BorderBrush" Value="#409EFF"/>
                                </Trigger>
                                <MultiTrigger>
                                    <MultiTrigger.Conditions>
                                        <Condition Property="IsSelected" Value="True"/>
                                        <Condition Property="IsKeyboardFocusWithin" Value="True"/>
                                    </MultiTrigger.Conditions>
                                    <Setter Property="Background" Value="#DCEEFF"/>
                                    <Setter Property="BorderBrush" Value="#409EFF"/>
                                    <Setter Property="Foreground" Value="#174F80"/>
                                </MultiTrigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Foreground" Value="#A8ABB2"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.CellStyle>

                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="BorderBrush" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="3,0,0,0"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#F5F7FA"/>
                                </Trigger>
                                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                    <Setter Property="Background" Value="#F4F9FF"/>
                                    <Setter Property="BorderBrush" Value="#79BBFF"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#ECF5FF"/>
                                    <Setter Property="BorderBrush" Value="#409EFF"/>
                                </Trigger>
                                <MultiTrigger>
                                    <MultiTrigger.Conditions>
                                        <Condition Property="IsSelected" Value="True"/>
                                        <Condition Property="IsMouseOver" Value="True"/>
                                    </MultiTrigger.Conditions>
                                    <Setter Property="Background" Value="#E2F0FF"/>
                                    <Setter Property="BorderBrush" Value="#409EFF"/>
                                </MultiTrigger>
                                <MultiTrigger>
                                    <MultiTrigger.Conditions>
                                        <Condition Property="IsSelected" Value="True"/>
                                        <Condition Property="IsKeyboardFocusWithin" Value="True"/>
                                    </MultiTrigger.Conditions>
                                    <Setter Property="Background" Value="#DCEEFF"/>
                                    <Setter Property="BorderBrush" Value="#409EFF"/>
                                </MultiTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="64"
                                            SortMemberPath="Id" CanUserSort="True"
                                            HeaderStyle="{StaticResource CenterColumnHeaderStyle}"
                                            ElementStyle="{StaticResource CenterCellText}"/>
                        <DataGridTextColumn Header="商品编码" Binding="{Binding Code}" Width="130"
                                            SortMemberPath="Code" CanUserSort="True"/>
                        <DataGridTextColumn Header="商品名称" Binding="{Binding Name}" Width="160"
                                            SortMemberPath="Name" CanUserSort="True"/>
                        <DataGridTextColumn Header="价格" Binding="{Binding Price, StringFormat={}{0:N2}}" Width="110"
                                            SortMemberPath="Price" CanUserSort="True"
                                            HeaderStyle="{StaticResource RightColumnHeaderStyle}"
                                            ElementStyle="{StaticResource RightCellText}"/>
                        <DataGridTextColumn Header="库存" Binding="{Binding Stock, StringFormat={}{0:N0}}" Width="90"
                                            SortMemberPath="Stock" CanUserSort="True"
                                            HeaderStyle="{StaticResource RightColumnHeaderStyle}"
                                            ElementStyle="{StaticResource RightCellText}"/>
                        <DataGridTextColumn Header="描述" Binding="{Binding Description}" Width="*"
                                            CanUserSort="False"
                                            ElementStyle="{StaticResource DescriptionCellText}"/>
                    </DataGrid.Columns>
                </DataGrid>

                <Border Panel.ZIndex="10" Background="White"
                        Visibility="{Binding IsEmpty, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="暂无商品" FontSize="15" FontWeight="SemiBold"
                                   Foreground="#303133" HorizontalAlignment="Center"/>
                        <TextBlock Text="当前列表中没有商品数据"
                                   Foreground="#606266" FontSize="12" Margin="0,6,0,0"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Panel.ZIndex="15" Background="White"
                        AutomationProperties.LiveSetting="Polite"
                        Visibility="{Binding HasNoSearchResults, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                MaxWidth="360">
                        <TextBlock Text="未找到匹配商品" FontSize="15" FontWeight="SemiBold"
                                   Foreground="#303133" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding NoSearchResultsMessage}"
                                   Foreground="#606266" FontSize="12" Margin="0,6,0,12"
                                   TextWrapping="Wrap" TextAlignment="Center"/>
                        <Button Content="清空搜索" Width="92"
                                Style="{StaticResource DefaultButton}"
                                Command="{Binding ClearSearchCommand}"/>
                    </StackPanel>
                </Border>

                <Border Panel.ZIndex="20" Background="White"
                        AutomationProperties.LiveSetting="Assertive"
                        Visibility="{Binding HasLoadError, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                MaxWidth="360">
                        <TextBlock Text="商品列表加载失败" FontSize="15" FontWeight="SemiBold"
                                   Foreground="#C53030" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding LoadErrorMessage}"
                                   Foreground="#606266" FontSize="12" Margin="0,6,0,12"
                                   TextWrapping="Wrap" TextAlignment="Center"/>
                        <Button Content="重新加载" Width="92"
                                Style="{StaticResource DefaultButton}"
                                Command="{Binding DataContext.RefreshCommand,
                                                  RelativeSource={RelativeSource AncestorType=Window}}"/>
                    </StackPanel>
                </Border>

                <Border Panel.ZIndex="30" Background="#F2FFFFFF"
                        AutomationProperties.LiveSetting="Polite"
                        Visibility="{Binding IsRefreshing, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <ProgressBar Width="180" Height="4"
                                     IsIndeterminate="True"
                                     Foreground="#409EFF" Background="#E4E7ED"/>
                        <TextBlock Text="{Binding LoadingMessage}"
                                   Foreground="#606266" FontSize="12" Margin="0,10,0,0"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </DockPanel>
    </Border>
</UserControl>
