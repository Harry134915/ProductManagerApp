<UserControl x:Class="ProductManagerApp.Views.ProductFormView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:ProductManagerApp.Views.Converters">

    <UserControl.Resources>
        <local:TextEmptyToVisibilityConverter x:Key="TextEmptyToVisibilityConverter"/>
        <local:NotNullToBoolConverter x:Key="NotNullToBoolConverter"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <Style x:Key="FormTextBoxStyle"
               TargetType="TextBox"
               BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Validation.ErrorTemplate">
                <Setter.Value>
                    <ControlTemplate>
                        <AdornedElementPlaceholder/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Validation.HasError" Value="True">
                    <Setter Property="BorderBrush" Value="#C53030"/>
                    <Setter Property="BorderThickness" Value="1"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FieldErrorTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#C53030"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="AutomationProperties.LiveSetting" Value="Assertive"/>
        </Style>
    </UserControl.Resources>

    <Border Background="White" CornerRadius="6" Padding="16"
            BorderBrush="#EBEEF5" BorderThickness="1" Margin="0,0,0,8">
        <StackPanel>

            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="{Binding DataContext.FormTitle,
                                          RelativeSource={RelativeSource AncestorType=Window}}"
                           FontSize="15" FontWeight="SemiBold"
                           Foreground="#303133"/>
                <TextBlock Grid.Column="1"
                           Text="{Binding DataContext.FormModeHint,
                                          RelativeSource={RelativeSource AncestorType=Window}}"
                           Foreground="#B1B7C0" FontSize="11"
                           VerticalAlignment="Center"/>
            </Grid>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <Label Target="{Binding ElementName=CodeBox}"
                           Padding="0" Margin="0,0,0,4">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="商品编码" Foreground="#606266" FontSize="12"/>
                            <TextBlock Text=" *" Foreground="#C53030" FontSize="12"/>
                        </StackPanel>
                    </Label>
                    <Grid>
                        <TextBox x:Name="CodeBox"
                                 Tag="Code"
                                 Style="{StaticResource FormTextBoxStyle}"
                                 InputMethod.IsInputMethodEnabled="False"
                                 LostKeyboardFocus="OnFieldLostKeyboardFocus"
                                 Text="{Binding Code,
                                                UpdateSourceTrigger=PropertyChanged,
                                                ValidatesOnNotifyDataErrors=True}"
                                 IsReadOnly="{Binding DataContext.List.SelectedProduct,
                                             Converter={StaticResource NotNullToBoolConverter},
                                             RelativeSource={RelativeSource AncestorType=Window}}"/>

                        <TextBlock Text="请输入商品编码" Foreground="#C0C4CC"
                                   Margin="8,0,0,0" VerticalAlignment="Center"
                                   IsHitTestVisible="False">
                            <TextBlock.Visibility>
                                <MultiBinding Converter="{StaticResource TextEmptyToVisibilityConverter}">
                                    <Binding ElementName="CodeBox" Path="Text"/>
                                    <Binding ElementName="CodeBox" Path="IsKeyboardFocused"/>
                                </MultiBinding>
                            </TextBlock.Visibility>
                        </TextBlock>
                    </Grid>

                    <TextBlock Style="{StaticResource FieldErrorTextStyle}"
                               Text="{Binding ElementName=CodeBox,
                                              Path=(Validation.Errors)[0].ErrorContent}"
                               Visibility="{Binding ElementName=CodeBox,
                                                    Path=(Validation.HasError),
                                                    Converter={StaticResource BooleanToVisibilityConverter}}"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <Label Target="{Binding ElementName=NameBox}"
                           Padding="0" Margin="0,0,0,4">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="商品名称" Foreground="#606266" FontSize="12"/>
                            <TextBlock Text=" *" Foreground="#C53030" FontSize="12"/>
                        </StackPanel>
                    </Label>
                    <Grid>
                        <TextBox x:Name="NameBox"
                                 Tag="Name"
                                 Style="{StaticResource FormTextBoxStyle}"
                                 LostKeyboardFocus="OnFieldLostKeyboardFocus"
                                 Text="{Binding Name,
                                                UpdateSourceTrigger=PropertyChanged,
                                                ValidatesOnNotifyDataErrors=True}"/>
                        <TextBlock Text="请输入商品名称" Foreground="#C0C4CC"
                                   Margin="8,0,0,0" VerticalAlignment="Center"
                                   IsHitTestVisible="False">
                            <TextBlock.Visibility>
                                <MultiBinding Converter="{StaticResource TextEmptyToVisibilityConverter}">
                                    <Binding ElementName="NameBox" Path="Text"/>
                                    <Binding ElementName="NameBox" Path="IsKeyboardFocused"/>
                                </MultiBinding>
                            </TextBlock.Visibility>
                        </TextBlock>
                    </Grid>

                    <TextBlock Style="{StaticResource FieldErrorTextStyle}"
                               Text="{Binding ElementName=NameBox,
                                              Path=(Validation.Errors)[0].ErrorContent}"
                               Visibility="{Binding ElementName=NameBox,
                                                    Path=(Validation.HasError),
                                                    Converter={StaticResource BooleanToVisibilityConverter}}"/>
                </StackPanel>

                <StackPanel Grid.Column="4">
                    <Label Target="{Binding ElementName=PriceBox}"
                           Padding="0" Margin="0,0,0,4">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="价格" Foreground="#606266" FontSize="12"/>
                            <TextBlock Text=" *" Foreground="#C53030" FontSize="12"/>
                        </StackPanel>
                    </Label>
                    <Grid>
                        <TextBox x:Name="PriceBox"
                                 Tag="Price"
                                 Style="{StaticResource FormTextBoxStyle}"
                                 PreviewTextInput="OnNumericPreviewTextInput"
                                 DataObject.Pasting="OnNumericPaste"
                                 LostKeyboardFocus="OnFieldLostKeyboardFocus"
                                 Text="{Binding Price,
                                                UpdateSourceTrigger=PropertyChanged,
                                                ValidatesOnNotifyDataErrors=True}"/>
                        <TextBlock Text="请输入价格" Foreground="#C0C4CC"
                                   Margin="8,0,0,0" VerticalAlignment="Center"
                                   IsHitTestVisible="False">
                            <TextBlock.Visibility>
                                <MultiBinding Converter="{StaticResource TextEmptyToVisibilityConverter}">
                                    <Binding ElementName="PriceBox" Path="Text"/>
                                    <Binding ElementName="PriceBox" Path="IsKeyboardFocused"/>
                                </MultiBinding>
                            </TextBlock.Visibility>
                        </TextBlock>
                    </Grid>

                    <TextBlock Style="{StaticResource FieldErrorTextStyle}"
                               Text="{Binding ElementName=PriceBox,
                                              Path=(Validation.Errors)[0].ErrorContent}"
                               Visibility="{Binding ElementName=PriceBox,
                                                    Path=(Validation.HasError),
                                                    Converter={StaticResource BooleanToVisibilityConverter}}"/>
                </StackPanel>

                <StackPanel Grid.Column="6">
                    <Label Target="{Binding ElementName=StockBox}"
                           Padding="0" Margin="0,0,0,4">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="库存" Foreground="#606266" FontSize="12"/>
                            <TextBlock Text=" *" Foreground="#C53030" FontSize="12"/>
                        </StackPanel>
                    </Label>
                    <Grid>
                        <TextBox x:Name="StockBox"
                                 Tag="Stock"
                                 Style="{StaticResource FormTextBoxStyle}"
                                 PreviewTextInput="OnNumericPreviewTextInput"
                                 DataObject.Pasting="OnNumericPaste"
                                 LostKeyboardFocus="OnFieldLostKeyboardFocus"
                                 Text="{Binding Stock,
                                                UpdateSourceTrigger=PropertyChanged,
                                                ValidatesOnNotifyDataErrors=True}"/>
                        <TextBlock Text="请输入库存" Foreground="#C0C4CC"
                                   Margin="8,0,0,0" VerticalAlignment="Center"
                                   IsHitTestVisible="False">
                            <TextBlock.Visibility>
                                <MultiBinding Converter="{StaticResource TextEmptyToVisibilityConverter}">
                                    <Binding ElementName="StockBox" Path="Text"/>
                                    <Binding ElementName="StockBox" Path="IsKeyboardFocused"/>
                                </MultiBinding>
                            </TextBlock.Visibility>
                        </TextBlock>
                    </Grid>

                    <TextBlock Style="{StaticResource FieldErrorTextStyle}"
                               Text="{Binding ElementName=StockBox,
                                              Path=(Validation.Errors)[0].ErrorContent}"
                               Visibility="{Binding ElementName=StockBox,
                                                    Path=(Validation.HasError),
                                                    Converter={StaticResource BooleanToVisibilityConverter}}"/>
                </StackPanel>

                <StackPanel Grid.Column="8">
                    <Label Target="{Binding ElementName=DescBox}"
                           Padding="0" Margin="0,0,0,4">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="描述" Foreground="#606266" FontSize="12"/>
                            <TextBlock Text=" *" Foreground="#C53030" FontSize="12"/>
                        </StackPanel>
                    </Label>
                    <Grid>
                        <TextBox x:Name="DescBox"
                                 Tag="Description"
                                 Style="{StaticResource FormTextBoxStyle}"
                                 LostKeyboardFocus="OnFieldLostKeyboardFocus"
                                 Text="{Binding Description,
                                                UpdateSourceTrigger=PropertyChanged,
                                                ValidatesOnNotifyDataErrors=True}"/>
                        <TextBlock Text="请输入描述" Foreground="#C0C4CC"
                                   Margin="8,0,0,0" VerticalAlignment="Center"
                                   IsHitTestVisible="False">
                            <TextBlock.Visibility>
                                <MultiBinding Converter="{StaticResource TextEmptyToVisibilityConverter}">
                                    <Binding ElementName="DescBox" Path="Text"/>
                                    <Binding ElementName="DescBox" Path="IsKeyboardFocused"/>
                                </MultiBinding>
                            </TextBlock.Visibility>
                        </TextBlock>
                    </Grid>

                    <TextBlock Style="{StaticResource FieldErrorTextStyle}"
                               Text="{Binding ElementName=DescBox,
                                              Path=(Validation.Errors)[0].ErrorContent}"
                               Visibility="{Binding ElementName=DescBox,
                                                    Path=(Validation.HasError),
                                                    Converter={StaticResource BooleanToVisibilityConverter}}"/>
                </StackPanel>
            </Grid>

            <!-- 按钮行 -->
            <Grid Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="填写完整信息后可新增商品；选中列表项后可更新或删除。"
                           Foreground="#A8ABB2" FontSize="12"
                           VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Width="92" Padding="12,0" Margin="0,0,8,0"
                            Command="{Binding DataContext.AddCommand,
                                              RelativeSource={RelativeSource AncestorType=Window}}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                                <Setter Property="Content" Value="添加商品"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DataContext.AddCommand.IsExecuting,
                                                                   RelativeSource={RelativeSource AncestorType=Window}}"
                                                 Value="True">
                                        <Setter Property="Content" Value="正在添加…"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Width="92" Padding="12,0" Margin="0,0,8,0"
                            Command="{Binding DataContext.UpdateCommand,
                                              RelativeSource={RelativeSource AncestorType=Window}}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                                <Setter Property="Content" Value="更新商品"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DataContext.UpdateCommand.IsExecuting,
                                                                   RelativeSource={RelativeSource AncestorType=Window}}"
                                                 Value="True">
                                        <Setter Property="Content" Value="正在更新…"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Content="删除商品" Width="92" Margin="0,0,16,0"
                        Style="{StaticResource DangerButton}"
                        Command="{Binding DataContext.DeleteCommand,
                                  RelativeSource={RelativeSource AncestorType=Window}}"/>

                    <Button Content="{Binding DataContext.ClearFormButtonText,
                                              RelativeSource={RelativeSource AncestorType=Window}}"
                        Width="92" Margin="0,0,8,0"
                        Style="{StaticResource DefaultButton}"
                        Command="{Binding DataContext.ClearFormCommand,
                                  RelativeSource={RelativeSource AncestorType=Window}}"/>

                    <Button Width="80" Padding="8,0"
                            Command="{Binding DataContext.RefreshCommand,
                                              RelativeSource={RelativeSource AncestorType=Window}}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource DefaultButton}">
                                <Setter Property="Content" Value="刷新"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DataContext.RefreshCommand.IsExecuting,
                                                                   RelativeSource={RelativeSource AncestorType=Window}}"
                                                 Value="True">
                                        <Setter Property="Content" Value="正在刷新…"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>

        </StackPanel>
    </Border>
</UserControl>
