<UserControl x:Class="ProductManagerApp.Views.ProductFormView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:ProductManagerApp.Views.Converters">

    <UserControl.Resources>
        <local:TextEmptyToVisibilityConverter x:Key="TextEmptyToVisibilityConverter"/>
    </UserControl.Resources>

    <Border Background="White" CornerRadius="6" Padding="16"
            BorderBrush="#EBEEF5" BorderThickness="1" Margin="0,0,0,12">
        <StackPanel>

            <!-- 标题 -->
            <TextBlock Text="商品管理系统" FontSize="15" FontWeight="SemiBold"
                       Foreground="#303133" Margin="0,0,0,12"/>

            <!-- 输入框行 -->
            <WrapPanel Orientation="Horizontal">

                <!-- 商品编码 -->
                <StackPanel Margin="0,0,16,8">
                    <TextBlock Text="商品编码" Foreground="#606266" FontSize="12" Margin="0,0,0,4"/>
                    <Grid>
                        <TextBox x:Name="CodeBox" Width="150"
                                 Text="{Binding Code, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Text="请输入商品编码" Foreground="#C0C4CC"
                                   Margin="8,0,0,0" VerticalAlignment="Center"
                                   IsHitTestVisible="False">
                            <TextBlock.Visibility>
                                <MultiBinding Converter="{StaticResource TextEmptyToVisibilityConverter}">
                                    <Binding ElementName="CodeBox" Path="Text"/>
                                    <Binding ElementName="CodeBox" Path="IsKeyboardFocused"/>
                                </MultiBinding>
                            </TextBlock.Visibility>
                        </TextBlock>
                    </Grid>
                </StackPanel>

                <!-- 商品名称 -->
                <StackPanel Margin="0,0,16,8">
                    <TextBlock Text="商品名称" Foreground="#606266" FontSize="12" Margin="0,0,0,4"/>
                    <Grid>
                        <TextBox x:Name="NameBox" Width="150"
                                 Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Text="请输入商品名称" Foreground="#C0C4CC"
                                   Margin="8,0,0,0" VerticalAlignment="Center"
                                   IsHitTestVisible="False">
                            <TextBlock.Visibility>
                                <MultiBinding Converter="{StaticResource TextEmptyToVisibilityConverter}">
                                    <Binding ElementName="NameBox" Path="Text"/>
                                    <Binding ElementName="NameBox" Path="IsKeyboardFocused"/>
                                </MultiBinding>
                            </TextBlock.Visibility>
                        </TextBlock>
                    </Grid>
                </StackPanel>

                <!-- 价格 -->
                <StackPanel Margin="0,0,16,8">
                    <TextBlock Text="价格" Foreground="#606266" FontSize="12" Margin="0,0,0,4"/>
                    <Grid>
                        <TextBox x:Name="PriceBox" Width="120"
                                 Text="{Binding Price, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Text="请输入价格" Foreground="#C0C4CC"
                                   Margin="8,0,0,0" VerticalAlignment="Center"
                                   IsHitTestVisible="False">
                            <TextBlock.Visibility>
                                <MultiBinding Converter="{StaticResource TextEmptyToVisibilityConverter}">
                                    <Binding ElementName="PriceBox" Path="Text"/>
                                    <Binding ElementName="PriceBox" Path="IsKeyboardFocused"/>
                                </MultiBinding>
                            </TextBlock.Visibility>
                        </TextBlock>
                    </Grid>
                </StackPanel>

                <!-- 库存 -->
                <StackPanel Margin="0,0,16,8">
                    <TextBlock Text="库存" Foreground="#606266" FontSize="12" Margin="0,0,0,4"/>
                    <Grid>
                        <TextBox x:Name="StockBox" Width="100"
                                 Text="{Binding Stock, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Text="请输入库存" Foreground="#C0C4CC"
                                   Margin="8,0,0,0" VerticalAlignment="Center"
                                   IsHitTestVisible="False">
                            <TextBlock.Visibility>
                                <MultiBinding Converter="{StaticResource TextEmptyToVisibilityConverter}">
                                    <Binding ElementName="StockBox" Path="Text"/>
                                    <Binding ElementName="StockBox" Path="IsKeyboardFocused"/>
                                </MultiBinding>
                            </TextBlock.Visibility>
                        </TextBlock>
                    </Grid>
                </StackPanel>

                <!-- 描述 -->
                <StackPanel Margin="0,0,0,8">
                    <TextBlock Text="描述" Foreground="#606266" FontSize="12" Margin="0,0,0,4"/>
                    <Grid>
                        <TextBox x:Name="DescBox" Width="160"
                                 Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Text="请输入描述" Foreground="#C0C4CC"
                                   Margin="8,0,0,0" VerticalAlignment="Center"
                                   IsHitTestVisible="False">
                            <TextBlock.Visibility>
                                <MultiBinding Converter="{StaticResource TextEmptyToVisibilityConverter}">
                                    <Binding ElementName="DescBox" Path="Text"/>
                                    <Binding ElementName="DescBox" Path="IsKeyboardFocused"/>
                                </MultiBinding>
                            </TextBlock.Visibility>
                        </TextBlock>
                    </Grid>
                </StackPanel>

            </WrapPanel>

            <!-- 按钮行 -->
            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                <Button Content="添加商品" Width="88" Margin="0,0,8,0"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding DataContext.AddCommand,
                                  RelativeSource={RelativeSource AncestorType=Window}}"/>

                <Button Content="更新商品" Width="88" Margin="0,0,8,0"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding DataContext.UpdateCommand,
                                  RelativeSource={RelativeSource AncestorType=Window}}"/>

                <Button Content="删除商品" Width="88" Margin="0,0,8,0"
                        Style="{StaticResource DangerButton}"
                        Command="{Binding DataContext.DeleteCommand,
                                  RelativeSource={RelativeSource AncestorType=Window}}"/>

                <Button Content="刷新" Width="72"
                        Style="{StaticResource DefaultButton}"
                        Command="{Binding DataContext.RefreshCommand,
                                  RelativeSource={RelativeSource AncestorType=Window}}"/>
            </StackPanel>

        </StackPanel>
    </Border>
</UserControl>
