<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- 基础控件颜色：名称表达用途，后续调整主题时无需修改控件模板。 -->
    <SolidColorBrush x:Key="ControlBackgroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ControlBorderBrush" Color="#DCDFE6"/>
    <SolidColorBrush x:Key="PrimaryBrush" Color="#409EFF"/>
    <SolidColorBrush x:Key="PrimaryHoverBrush" Color="#66B1FF"/>
    <SolidColorBrush x:Key="PrimaryFocusBorderBrush" Color="#1F6FB2"/>

    <!-- 只读和禁用状态保持低对比度，明确控件当前不可编辑。 -->
    <SolidColorBrush x:Key="ReadOnlyBackgroundBrush" Color="#F5F7FA"/>
    <SolidColorBrush x:Key="ReadOnlyTextBrush" Color="#909399"/>
    <SolidColorBrush x:Key="DisabledBackgroundBrush" Color="#E4E7ED"/>
    <SolidColorBrush x:Key="DisabledTextBrush" Color="#A8ABB2"/>
    <SolidColorBrush x:Key="DefaultDisabledTextBrush" Color="#C0C4CC"/>

    <!-- 危险操作和次要按钮使用独立状态色，避免与主操作混淆。 -->
    <SolidColorBrush x:Key="DangerBrush" Color="#F56C6C"/>
    <SolidColorBrush x:Key="DangerHoverBrush" Color="#F78989"/>
    <SolidColorBrush x:Key="DangerFocusBorderBrush" Color="#C53030"/>
    <SolidColorBrush x:Key="DangerDisabledBackgroundBrush" Color="#F1F3F6"/>
    <SolidColorBrush x:Key="DangerDisabledTextBrush" Color="#B1B7C0"/>
    <SolidColorBrush x:Key="DefaultTextBrush" Color="#606266"/>
    <SolidColorBrush x:Key="DefaultHoverBackgroundBrush" Color="#ECF5FF"/>
</ResourceDictionary>
